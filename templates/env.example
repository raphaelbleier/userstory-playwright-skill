# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# Where the app under test is reachable.
BASE_URL=http://localhost:3000

# The command that starts your app, if it is not already running.
# The skill asks you for this rather than guessing it from package.json.
# To use it, uncomment the `webServer` block in playwright.config.ts.
DEV_COMMAND=npm run dev

# A test account. Only needed for stories with `Requires Auth = yes`.
# Use a dedicated test user on a non-production environment.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
